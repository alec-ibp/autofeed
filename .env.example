# Copia este archivo a `.env` (gitignored) y rellena solo lo que uses.

# --- LLM provider ---
# Setea la key del provider que tengas activo en feeds.yaml > settings.model.
# Cambiar de provider = editar `settings.model` + setear la env var correspondiente.
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=

# --- Email delivery (opcional) ---
# Si delivery.email.enabled = true en feeds.yaml, estas dos son requeridas.
# Sin RESEND_API_KEY o EMAIL_TO, el envío se omite con un warning (digest se commitea igual).
RESEND_API_KEY=
EMAIL_TO=
